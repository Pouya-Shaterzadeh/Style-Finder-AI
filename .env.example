# ============================================================
# Style Finder AI — Environment Variables
# ============================================================
# 1. Copy this file to .env:
#       cp .env.example .env
# 2. Fill in the values below.
# 3. Never commit .env — it is already in .gitignore.
# ============================================================

# -----------------------------------------------------------
# REQUIRED — Groq API key for Llama 4 Scout VLM
# Free tier: no credit card required (~14 400 requests/day)
# Get yours at https://console.groq.com
# -----------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# -----------------------------------------------------------
# OPTIONAL — Hugging Face token
# Speeds up the first download of the fashion-CLIP model.
# Get yours at https://huggingface.co/settings/tokens
# -----------------------------------------------------------
HF_API_TOKEN=
